{
  "name": "@keysark/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "keysark": "./dist/keysark.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node20 --banner:js='#!/usr/bin/env node' --outfile=dist/keysark.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@keysark/crypto": "workspace:*",
    "@keysark/vault": "workspace:*",
    "esbuild": "^0.27.0"
  }
}
